# RAG app

DEBUG_MODE_ENABLED=false
OPENWEBUI_RERANKING_ENABLED=false

## llma provider api key
GOOGLE_API_KEY=""

## chunking config
MAX_TOKENS=1024
OVERLAP_TOKENS=200

## title generation
TITLE_GEN_ENABLED=false
TITLE_GEN_MODEL="gemma-3-27b-it"
TITLE_MAX_TOKENS=50

## speech to text
SPEECH_TO_TEXT_MODEL_SIZE="medium"

## embedding model
EMBEDDING_MODEL="gemini-embedding-001"
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DIM=1024

## reranking model
RERANKER_MODEL="BAAI/bge-reranker-v2-m3"
OVERFETCH_MULTIPLIER=2.0

## utils
FUSION_METHOD="dbsf"
RRF_K=2
FUSION_ALPHA=0.7

## generation config
GENERATION_MODEL="gemma-3-27b-it"
GENERATION_MAX_TOKENS=512
GENERATION_TEMPERATURE=0.7
GENERATION_CONTEXT_WINDOW=8192
GENERATION_HISTORY_TURNS=10
GENERATION_RAG_TOP_K=5
GENERATION_SEARCH_TYPE="hybrid"

# storage
## milvus
MILVUS_URI="http://localhost:19530"
MILVUS_DB_NAME="default"
MILVUS_USER=""
MILVUS_PASSWORD=""
MILVUS_TOKEN=""
MILVUS_TIMEOUT_SEC=30

MILVUS_METRIC_TYPE="COSINE"
MILVUS_INDEX_TYPE="HNSW"
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_HNSW_EF=64

MILVUS_INSERT_BATCH_SIZE=512
MILVUS_ENABLE_FULLTEXT=false
MILVUS_TEXT_MAX_LENGTH=9000

CONVERSATION_META_COLLECTION="_conversation_meta"
CONVERSATION_MSG_COLLECTION="_conversation_messages"

## redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD="" # set the same value as in compose.env
REDIS_DB=0
REDIS_JOB_TTL_SEC=3600

## local
LOCAL_STORAGE_PATH="./.storage"

# backend
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000

